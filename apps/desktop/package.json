{
  "name": "wovly",
  "productName": "Wovly",
  "private": true,
  "version": "0.1.0",
  "description": "Your autonomous communication agent - AI assistant for Email, Slack, and iMessage",
  "author": "Wovly <hello@wovly.com>",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc && npm run build:ui && electron-builder --mac",
    "build:ui": "npm run -w apps/ui build",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --mac --win --linux",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@playwright/mcp": "^0.0.61",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "@wovly/agent-core": "*",
    "@wovly/llm": "*",
    "@wovly/memory": "*",
    "@wovly/tools": "*",
    "better-sqlite3": "^12.6.2",
    "esbuild": "^0.27.2",
    "esbuild-register": "^3.6.0",
    "inversify": "^7.11.0",
    "puppeteer-core": "^22.15.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.4.38",
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "electron": "^40.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.wovly.assistant",
    "productName": "Wovly",
    "electronVersion": "40.0.0",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "!dist/mac",
      "!dist/mac-arm64",
      "!dist/win-unpacked",
      "!dist/linux-unpacked",
      "!dist/*.dmg",
      "!dist/*.exe",
      "!dist/*.AppImage",
      "!dist/*.deb",
      "!dist/*.blockmap",
      "!dist/builder-debug.yml",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,changelog.md}",
      "!node_modules/**/*.{ts,map}"
    ],
    "extraResources": [
      {
        "from": "../ui/dist",
        "to": "ui",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Wovly",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icons"
    }
  }
}
