# Google OAuth Configuration (Desktop App Type)
# Required for Gmail, Google Calendar, and Google Drive integrations

# Get this from https://console.cloud.google.com
# Create OAuth credentials as "Desktop app" type (no client secret needed)
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Client secret NOT needed for Desktop app type (uses PKCE instead)
# GOOGLE_CLIENT_SECRET=

# Optional: Anthropic API Key (for LLM features)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional: Development settings
NODE_ENV=development
LOG_LEVEL=info
